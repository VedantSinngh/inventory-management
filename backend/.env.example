# ========================================
# INVENTORY MANAGEMENT SYSTEM
# Production Environment Configuration
# ========================================

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=production

# Log level: error, warn, info, http, debug, verbose, silly
LOG_LEVEL=info

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB connection string (use Atlas for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/databasename
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/inventorySystem?retryWrites=true&w=majority

# ===========================================
# JWT SECURITY
# ===========================================
# CRITICAL: Generate a strong JWT_SECRET
# Min 32 characters, cryptographically random
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long_replace_me_now

# JWT expiration
JWT_EXPIRY=30d

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Frontend URL (where the React app is hosted)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Socket.IO CORS origin (same as CORS_ORIGIN usually)
SOCKET_IO_CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Frontend URL for email links
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ===========================================
# EMAIL SERVICE (SendGrid)
# ===========================================
# SendGrid API Key (get from https://app.sendgrid.com)
# Required for production email verification and password reset
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Email sender address (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=noreply@inventory-system.com

# Support/Reply-to email
SUPPORT_EMAIL=support@inventory-system.com

# ===========================================
# EXTERNAL API SERVICES
# ===========================================
# Maps API (Mapbox or Google Maps)
MAPBOX_API_KEY=your_mapbox_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
MAPS_PROVIDER=mapbox

# Weather API (OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ===========================================
# REDIS CONFIGURATION (Optional)
# ===========================================
# For caching and session management
# Example: redis://username:password@redis-host:6379
REDIS_URL=

# ===========================================
# MONITORING & LOGGING
# ===========================================
# Sentry DSN (optional, for error tracking)
SENTRY_DSN=

# New Relic License Key (optional, for APM)
NEW_RELIC_LICENSE_KEY=

# ===========================================
# DATABASE BACKUP
# ===========================================
# AWS S3 bucket for backups (optional)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===========================================
# SECURITY
# ===========================================
# Enable HTTPS only in production
HTTPS_ONLY=true

# Session timeout (in minutes)
SESSION_TIMEOUT=30

# Rate limiting window (in minutes)
RATE_LIMIT_WINDOW=15

# Rate limiting max attempts
RATE_LIMIT_MAX_ATTEMPTS=5

# ===========================================
# API VERSIONING
# ===========================================
API_VERSION=v1

# ===========================================
# FEATURE FLAGS
# ===========================================
# Enable/disable features
FEATURE_EMAIL_VERIFICATION=true
FEATURE_PASSWORD_RESET=true
FEATURE_TWO_FACTOR_AUTH=false

# ===========================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ===========================================
# 1. Generate JWT_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. MongoDB Atlas Setup:
#    - Create cluster on MongoDB Atlas
#    - Whitelist your IP address
#    - Create database user with strong password
#    - Get connection string
#
# 3. SendGrid Setup:
#    - Create SendGrid account
#    - Verify sender email address
#    - Get API key
#
# 4. Deployment:
#    - Railway: Set env vars in settings
#    - Render: Create .env file in settings
#    - Heroku: Use heroku config:set
#    - AWS: Use Secrets Manager or Parameter Store
#
# 5. Security Checklist:
#    ☐ JWT_SECRET is strong (32+ chars, no defaults)
#    ☐ CORS_ORIGIN is set to production domain
#    ☐ SendGrid configured for email
#    ☐ HTTPS enabled
#    ☐ Database credentials secured
#    ☐ No sensitive data in git
#    ☐ Rate limiting enabled
#    ☐ Error logging configured
#    ☐ Backups configured
#    ☐ Monitoring setup
#
# 6. Post-Deployment:
#    - Test health endpoint: GET /api/health
#    - Test login: POST /api/auth/login
#    - Check logs for errors
#    - Monitor performance
#    - Verify email delivery
#    - Test WebSocket connection
