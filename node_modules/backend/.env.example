# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration (Use MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/inventorySystem?retryWrites=true&w=majority

# JWT Configuration (Generate a strong secret - min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long_1234567890

# CORS Configuration (Your Vercel Frontend URL)
CORS_ORIGIN=https://your-frontend-name.vercel.app

# Socket.io Configuration
SOCKET_IO_CORS_ORIGIN=https://your-frontend-name.vercel.app
SOCKET_IO_CORS_CREDENTIALS=true

# Vercel Settings
VERCEL_ENV=production
